    border-top: none; /* === ไม่ให้มีขอบด้านบน === */
}

/* === ขาตั้งด้านขวา - แก้ไขให้แสดงผล === */
.counter-bar-2::after {
    content: '';
    position: absolute;
    right: 0; /* === ลบ px === */
    top: 100%; /* เริ่มจากด้านล่างของ counter bar */
    width: 32px; /* === เปลี่ยนจาก % เป็น px เพื่อให้แสดงผลชัด === */
    height: 40px; /* === คงไว้เป็น px === */
    background: #67453d;
    z-index: 4;
    border-top: none; /* === ไม่ให้มีขอบด้านบน === */
}

/* === RESPONSIVE BREAKPOINTS === */
@media (max-width: 480px) {
    .counter-bar-2 {
        font-size: clamp(6px, 2.5vw, 8px);
        font-weight: 700;
        letter-spacing: 0.3px;
        min-height: 18px;
        padding: 2px 4px;
    }
    
    .counter-bar-2::before,
    .counter-bar-2::after {
        width: 12px; /* === ลดขนาดในหน้าจอเล็ก === */
        height: 20px; /* === ลดความสูงในหน้าจอเล็ก === */
    }
}

@media (min-width: 481px) and (max-width: 768px) {
