<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes, viewport-fit=cover">
    <title>เลือกโต๊ะ - ยักษ์ใหญ่แดนใต้ By TN</title>
    <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }
        
        :root {
            --primary-gradient: linear-gradient(135deg, #4E342E 0%, #8B4513 100%);
            --secondary-gradient: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            --vvip-color: linear-gradient(135deg, #ff6b6b 0%, #ee5a52 100%);
            --vip-color: linear-gradient(135deg, #a55eea 0%, #8b5cf6 100%);
            --normal-color: linear-gradient(135deg, #26de81 0%, #20bf6b 100%);
            --small-color: linear-gradient(135deg, #26bfde 0%, #20bfba 100%);
            --shadow-soft: 0 4px 20px rgba(0, 0, 0, 0.08);
            --shadow-medium: 0 8px 30px rgba(0, 0, 0, 0.12);
            --shadow-strong: 0 20px 60px rgba(0, 0, 0, 0.15);
            --border-radius: 24px;
            --border-radius-small: 16px;
            --text-dark: #1a202c;
            --text-medium: #4a5568;
            --text-light: #718096;
            --bg-overlay: rgba(255, 255, 255, 0.98);
            --glass-effect: rgba(255, 255, 255, 0.25);
            --accent-gold: #ffd700;
        }
        
        body {
            font-family: 'Kanit', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 30%, #f093fb 70%, #f5576c 100%);
            background-attachment: fixed;
            min-height: 100vh;
            color: var(--text-dark);
            overflow-x: hidden;
        }
        
        .container {
            max-width: 100%;
            margin: 0 auto;
            padding: 16px;
            background: var(--bg-overlay);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            min-height: 100vh;
            position: relative;
        }
        
        header {
            text-align: center;
            margin-bottom: 24px;
            padding: 32px 24px;
            background: var(--primary-gradient);
            border-radius: var(--border-radius);
            color: white;
            box-shadow: var(--shadow-strong);
        }
        
        h1 {
            font-size: clamp(24px, 6vw, 36px);
            font-weight: 700;
        }
        
        .subtitle {
            font-size: clamp(16px, 3.5vw, 20px);
            opacity: 0.95;
        }
        
        .loading, .error-display {
            text-align: center;
            padding: 100px 20px;
        }
        
        .spinner {
            display: inline-block;
            width: 60px;
            height: 60px;
            border: 5px solid rgba(102, 126, 234, 0.1);
            border-top: 5px solid #667eea;
            border-radius: 50%;
            animation: spin 1s cubic-bezier(0.68, -0.55, 0.265, 1.55) infinite;
            margin-bottom: 24px;
        }
        
        @keyframes spin { 
            0% { transform: rotate(0deg); } 
            100% { transform: rotate(360deg); } 
        }

        .success-screen {
            text-align: center;
            padding: 80px 20px;
        }
        
        .legend {
            display: grid;
            gap: 16px;
            margin-bottom: 32px;
            padding: 24px;
            background: var(--glass-effect);
            border-radius: var(--border-radius);
            box-shadow: var(--shadow-medium);
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .color-box {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            flex-shrink: 0;
            box-shadow: var(--shadow-soft);
        }
        
        .color-box.vvip { background: var(--vvip-color); }
        .color-box.vip { background: var(--vip-color); }
        .color-box.normal { background: var(--normal-color); }
        
        /* --- FLOOR SELECTOR STYLE --- */
        .floor-selector {
            display: flex;
            justify-content: center;
            gap: 12px;
            margin-bottom: 24px;
            padding: 8px;
            background: var(--glass-effect);
            backdrop-filter: blur(20px);
            border-radius: 60px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: var(--shadow-soft);
            max-width: 300px;
            margin-left: auto;
            margin-right: auto;
        }

        .floor-btn {
            padding: 12px 24px;
            font-family: 'Kanit', sans-serif;
            font-size: 16px;
            font-weight: 600;
            border: none;
            background: transparent;
            color: var(--text-medium);
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            min-width: 100px;
        }

        .floor-btn.active {
            background: var(--primary-gradient);
            color: white;
            box-shadow: var(--shadow-medium);
            transform: translateY(-2px);
        }

        .layout-wrapper {
            position: relative;
            margin-bottom: 40px;
            border-radius: 32px;
            overflow: hidden;
            box-shadow: var(--shadow-strong);
            background: var(--glass-effect);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        
        #restaurant-layout {
            position: relative;
            width: 100%;
            aspect-ratio: 100 / 75;
            background: var(--primary-gradient);
            overflow: auto;
            touch-action: pan-x pan-y;
            border-radius: 10px;
            padding: 10px;
            display: grid;
            grid-template-columns: repeat(100, 1fr);
            grid-template-rows: repeat(75, 1fr);
            gap: 1%;
        }
        
        .stage {
            grid-column: 38 / 62;
            grid-row: 1 / 16;
            background: var(--text-medium);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 0 0 15px 15px;
            font-weight: 700;
            font-size: clamp(11px, 2.2vw, 16px);
            z-index: 10;
            box-shadow: var(--shadow-medium);
            border: 2px solid rgba(255, 255, 255, 0.4);
            text-shadow: 0 2px 4px rgba(0,0,0,0.4);
            min-height: 30px;
        }

        .artist-room {
            grid-column: 24 / 39;
            grid-row: 1 / 5;
            background: var(--text-medium);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: clamp(10px, 2.2vw, 14px);
            z-index: 10;
            text-shadow: 0 2px 4px rgba(0,0,0,0.4);
            border: 2px solid rgba(255, 255, 255, 0.4);
            min-height: 30px;
        }

        .sound-room {
            grid-column: 61 / 74;
            grid-row: 1 / 5;
            background: var(--text-medium);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: clamp(10px, 2.2vw, 14px);
            z-index: 10;
            text-shadow: 0 2px 4px rgba(0,0,0,0.4);
            border: 2px solid rgba(255, 255, 255, 0.4);
            min-height: 30px;
        }

        .line-separator {
    background: #4E342E;
    /* คุณสามารถเพิ่มสไตล์อื่นๆ ที่ต้องการให้เหมือนกันทุกเส้นได้ที่นี่ */
    /* เช่น border-radius: 2px; */
}

/* === Responsive สำหรับทางเข้า === */
@media (max-width: 480px) {
    .artist-room,
    .sound-room {
        font-size: 6px;
    }
    
}

/* ตำแหน่ง A: สำหรับเส้นแบ่งตำแหน่งเดิมของคุณ */
.line-pos-1 {
    grid-column: 10 / 12;
    grid-row: 44 / 51;
}

/* ตำแหน่ง B: (ตัวอย่าง) สำหรับเส้นแบ่งที่อาจจะสร้างในอนาคต */
.line-pos-2 {
    grid-column: 1 / 3;
    grid-row: 44 / 51;
}

/* ตำแหน่ง A: สำหรับเส้นแบ่งตำแหน่งเดิมของคุณ */
.line-pos-3 {
    grid-column: 10 / 12;
    grid-row: 59 / 64;
}

/* ตำแหน่ง B: (ตัวอย่าง) สำหรับเส้นแบ่งที่อาจจะสร้างในอนาคต */
.line-pos-4 {
    grid-column: 1 / 3;
    grid-row: 59 / 64;
}

/* ตำแหน่ง B: (ตัวอย่าง) สำหรับเส้นแบ่งที่อาจจะสร้างในอนาคต */
.line-pos-5 {
    grid-column: 1 / 17;
    grid-row: 63 / 65;
}

/* ตำแหน่ง B: (ตัวอย่าง) สำหรับเส้นแบ่งที่อาจจะสร้างในอนาคต */
.line-pos-6 {
    grid-column: 15 / 17;
    grid-row: 63 / 74;
}

/* ตำแหน่ง B: (ตัวอย่าง) สำหรับเส้นแบ่งที่อาจจะสร้างในอนาคต */
.line-pos-7 {
    grid-column: 15 / 66;
    grid-row: 73 / 75;
}

/* ตำแหน่ง B: (ตัวอย่าง) สำหรับเส้นแบ่งที่อาจจะสร้างในอนาคต */
.line-pos-8 {
    grid-column: 64 / 66;
    grid-row: 69 / 74;
}

.line-pos-9 {
    grid-column: 64 / 66;
    grid-row: 63 / 66;
}

.line-pos-10 {
    grid-column: 64 / 101;
    grid-row: 63 / 65;
}

.line-pos-11 {
    grid-column: 65 / 69;
    grid-row: 73 / 75;
}

.line-pos-11 {
    grid-column: 65 / 69;
    grid-row: 73 / 75;
}

.line-pos-12 {
    grid-column: 74 / 80;
    grid-row: 73 / 75;
}

.line-pos-13 {
    grid-column: 78 / 80;
    grid-row: 63 / 75;
}

.line-pos-14 {
    grid-column: 99 / 101;
    grid-row: 52 / 65;
}

.line-pos-15 {
    grid-column: 17 / 30;
    grid-row: 1 / 3;
}

.line-pos-16 {
    grid-column: 17 / 19;
    grid-row: 1 / 4;
}

.line-pos-17 {
    grid-column: 1 / 18;
    grid-row: 2 / 4;
}

.line-pos-18 {
    grid-column: 73 / 78;
    grid-row: 1 / 3;
}

.line-pos-19 {
    grid-column: 85 / 87;
    grid-row: 1 / 4;
}

.line-pos-20 {
    grid-column: 86 / 101;
    grid-row: 2 / 4;
}

.line-pos-21 {
    grid-column: 44 / 46;
    grid-row: 60 / 74;
    z-index: 20;
}


/* === Responsive สำหรับทางเข้า === */
@media (max-width: 480px) {
    .line-pos-15{
        grid-row: 1 / 2;
    }

    .line-pos-16 {
    grid-row: 1 / 3;
}

    .line-pos-17 {
        grid-row: 2 / 3;
    }

    .line-pos-18 {
    grid-row: 1 / 2;
}

.line-pos-19 {
    grid-row: 1 / 3;
}

.line-pos-20 {
    grid-row: 2 / 3;
}
}

.rest-room {
  grid-column: 78 / 85;  /* เริ่มที่ col 80 ไปจน col 95 */
  grid-row: 1 / 10;      /* เริ่มแถว 2 ไปจนแถว 10 */
  display: flex;
  align-items: start;
  justify-content: center;
}

.rest-room img {
  max-width: 100%;
  height: auto;
}

.rest-room-left {
  grid-column: 4 / 10;  /* เริ่มที่ col 80 ไปจน col 95 */
  grid-row: 57 / 65;      /* เริ่มแถว 2 ไปจนแถว 10 */
  display: flex;
  align-items: start;
  justify-content: center;
}

.rest-room-left img {
  max-width: 100%;
  height: auto;
}

.elevate-text-1{
    grid-column: 2/5;
    grid-row: 5/10;
}

/* --- FIXED COUNTER BAR WITH VISIBLE LEGS --- */
.counter-bar {
    grid-column: 45 / 59;
    grid-row: 60 / 64;
    background: #4E342E;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: clamp(8px, 1.8vw, 16px);
    letter-spacing: clamp(0.2px, 0.5vw, 0.8px);
    text-shadow: 
        1px 1px 2px rgba(0, 0, 0, 0.8), 
        0 0 4px rgba(0, 0, 0, 0.5);
    z-index: 5;
    text-align: center;
    font-family: 'Kanit', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    position: relative;
    min-height: clamp(20px, 4vw, 32px);
    padding: clamp(2px, 1vw, 8px) clamp(4px, 2vw, 12px);
    overflow: visible; /* === เปลี่ยนจาก hidden เป็น visible === */
    white-space: nowrap;
}

/* === ขาตั้งด้านซ้าย - แก้ไขให้แสดงผล === */
.counter-bar::before {
    content: '';
    position: absolute;
    left: 0; /* === ลบ px === */
    top: 100%; /* เริ่มจากด้านล่างของ counter bar */
    width: 32px; /* === เปลี่ยนจาก % เป็น px เพื่อให้แสดงผลชัด === */
    height: 40px; /* === คงไว้เป็น px === */
    background: #4E342E;
    z-index: 4;
    border-top: none; /* === ไม่ให้มีขอบด้านบน === */
}

/* === ขาตั้งด้านขวา - แก้ไขให้แสดงผล === */
.counter-bar::after {
    content: '';
    position: absolute;
    right: 0; /* === ลบ px === */
    top: 100%; /* เริ่มจากด้านล่างของ counter bar */
    width: 32px; /* === เปลี่ยนจาก % เป็น px เพื่อให้แสดงผลชัด === */
    height: 40px; /* === คงไว้เป็น px === */
    background: #4E342E;
    z-index: 4;
    border-top: none; /* === ไม่ให้มีขอบด้านบน === */
}

/* === RESPONSIVE BREAKPOINTS === */
@media (max-width: 480px) {
    .counter-bar {
        font-size: clamp(4px, 2.5vw, 6px);
        font-weight: 700;
        letter-spacing: 0.3px;
        min-height: 18px;
        padding: 2px 4px;
    }
    
    .counter-bar::before,
    .counter-bar::after {
        width: 12px; /* === ลดขนาดในหน้าจอเล็ก === */
        height: 12px; /* === ลดความสูงในหน้าจอเล็ก === */
    }
}

@media (min-width: 481px) and (max-width: 768px) {
    .counter-bar {
        font-size: clamp(8px, 2vw, 11px);
        letter-spacing: 0.5px;
        min-height: 24px;
        padding: 4px 8px;
    }
    
    .counter-bar::before,
    .counter-bar::after {
        width: 26px;
        height: 30px;
    }
}

@media (min-width: 769px) and (max-width: 1024px) {
    .counter-bar {
        font-size: clamp(12px, 1.8vw, 15px);
        letter-spacing: 0.6px;
        min-height: 28px;
        padding: 6px 10px;
    }
    
    .counter-bar::before,
    .counter-bar::after {
        width: 30px;
        height: 35px;
    }
}

@media (min-width: 1025px) {
    .counter-bar {
        font-size: clamp(14px, 1.5vw, 18px);
        letter-spacing: 0.8px;
        min-height: 32px;
        padding: 8px 12px;
        font-weight: 700;
    }
    
    .counter-bar::before,
    .counter-bar::after {
        width: 35px;
        height: 45px;
    }
}

@media (min-width: 1440px) {
    .counter-bar {
        font-size: 20px;
        letter-spacing: 1px;
        min-height: 36px;
        padding: 10px 16px;
    }
    
    .counter-bar::before,
    .counter-bar::after {
        width: 40px;
        height: 50px;
    }
}

/* --- FIXED COUNTER BAR WITH VISIBLE LEGS --- */
.counter-bar-2 {
    grid-column: 45 / 59;
    grid-row: 56 / 60;
    background: #67453d;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: clamp(8px, 1.8vw, 16px);
    letter-spacing: clamp(0.2px, 0.5vw, 0.8px);
    text-shadow: 
        1px 1px 2px rgba(0, 0, 0, 0.8), 
        0 0 4px rgba(0, 0, 0, 0.5);
    z-index: 5;
    text-align: center;
    font-family: 'Kanit', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
