        font-size: clamp(8px, 2vw, 11px);
        letter-spacing: 0.5px;
        min-height: 24px;
        padding: 4px 8px;
    }
    
    .counter-bar-2::before,
    .counter-bar-2::after {
        width: 26px;
        height: 20px;
    }
}

@media (min-width: 769px) and (max-width: 1024px) {
    .counter-bar-2 {
        font-size: clamp(12px, 1.8vw, 15px);
        letter-spacing: 0.6px;
        min-height: 28px;
        padding: 6px 10px;
    }
    
    .counter-bar-2::before,
    .counter-bar-2::after {
        width: 30px;
        height: 25px;
    }
}

@media (min-width: 1025px) {
    .counter-bar-2 {
        font-size: clamp(14px, 1.5vw, 18px);
        letter-spacing: 0.8px;
        min-height: 32px;
        padding: 8px 12px;
        font-weight: 700;
    }
    
    .counter-bar-2::before,
    .counter-bar-2::after {
