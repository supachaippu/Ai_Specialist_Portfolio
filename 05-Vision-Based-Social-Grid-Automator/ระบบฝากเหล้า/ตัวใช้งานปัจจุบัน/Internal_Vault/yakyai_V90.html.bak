        height: 50px;
    }
}

/* === ป้ายบอกทางชั้น 2 ใต้เคาน์เตอร์บาร์ === */

.floor2-sign {
    grid-column: 56 / 40; /* ตำแหน่งใต้เคาน์เตอร์บาร์ */
    grid-row: 82 / 72;    /* ใต้เคาน์เตอร์บาร์ */
    position: relative;
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
}

/* พื้นหลังลายไม้ */
.floor2-sign::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: 
        repeating-linear-gradient(
            90deg,
            #ffffff 0px,
            #7d7d7d 8px,
            #505050 8px,
            #000000 9px
        );
    border: 2px solid #808080;
    border-radius: 4px;
    z-index: -2;
}

/* ป้ายลูกศรสีน้ำตาล */
.floor2-sign::after {
    content: '';
    position: absolute;
    top: 25%;
    left: 8%;
    right: 0%;
    bottom: 25%;
    background: #8B4513;
    z-index: -1;
    /* สร้างรูปลูกศรชี้ซ้าย */
    clip-path: polygon(
        15% 0%, 
        100% 0%, 
        100% 40%, 
        100% 60%, 
        100% 100%, 
        15% 100%, 
        0% 50%
    );
}

/* ข้อความ "ชั้น 2" */
.floor2-sign-text {
    color: white;
    font-family: 'Kanit', sans-serif;
    font-size: clamp(12px, 2.5vw, 18px);
    font-weight: 700;
    text-shadow: 
        1px 1px 2px rgba(0, 0, 0, 0.8),
        0 0 4px rgba(0, 0, 0, 0.6);
    z-index: 1;
    position: relative;
    letter-spacing: 1px;
    margin-left: 8px; /* เลื่อนข้อความไปขวาเล็กน้อย */
}


/* === Responsive Design === */
@media (max-width: 480px) {
    .floor2-sign {
        grid-column: 45 / 59;
        grid-row: 68 / 73;
    }
    
    .floor2-sign-text {
        font-size: 10px;
        letter-spacing: 0.5px;
        margin-left: 6px;
    }
    
    .floor2-sign::after {
        left: 10%;
        right: 20%;
    }
}

@media (min-width: 481px) and (max-width: 768px) {
    .floor2-sign {
        grid-column: 44 / 60;
        grid-row: 67 / 72;
    }
    
    .floor2-sign-text {
        font-size: 14px;
        margin-left: 7px;
    }
}

@media (min-width: 1025px) {
    .floor2-sign {
        grid-column: 44 / 60;
        grid-row: 68 / 73;
    }
    
    .floor2-sign-text {
        font-size: 20px;
        letter-spacing: 1.5px;
        margin-left: 10px;
    }
    
    .floor2-sign::after {
        left: 6%;
        right: 12%;
    }
}

/* === เอฟเฟกต์พิเศษเมื่อกำลังอยู่ชั้น 2 === */
.floor2-sign.current-floor::after {
    background: linear-gradient(135deg, #228B22 0%, #32CD32 100%);
    animation: glow 2s ease-in-out infinite alternate;
}

.floor2-sign.current-floor .floor2-sign-text {
    color: #FFFFFF;
    text-shadow: 
        1px 1px 2px rgba(0, 0, 0, 0.8),
        0 0 8px rgba(50, 205, 50, 0.6);
}

@keyframes glow {
    from {
        box-shadow: 
            inset 0 2px 4px rgba(255, 255, 255, 0.2),
            inset 0 -2px 4px rgba(0, 0, 0, 0.3),
            0 2px 6px rgba(0, 0, 0, 0.4);
    }
    to {
        box-shadow: 
            inset 0 2px 4px rgba(255, 255, 255, 0.3),
            inset 0 -2px 4px rgba(0, 0, 0, 0.4),
            0 4px 12px rgba(50, 205, 50, 0.6);
    }
}

/* === ป้ายชั้น 2 ใหม่ (ลูกศรชี้ขวา) === */
.floor2-sign-right {
    grid-column: 70 / 85;
    grid-row: 30 / 52;
    position: relative;
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
}

/* พื้นหลังลายไม้ */
.floor2-sign-right::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: 
        repeating-linear-gradient(
            90deg,
            #ffffff 0px,
            #7d7d7d 8px,
            #505050 8px,
            #000000 9px
        );
    border: 2px solid #808080;
    border-radius: 4px;
    z-index: -2;
}

/* ป้ายลูกศรสีน้ำตาล ชี้ขวา */
.floor2-sign-right::after {
    content: '';
    position: absolute;
    top: 25%;
    left: 8%;
    right: 8%;
    bottom: 25%;
    background: #8B4513;
    z-index: -1;
    /* สร้างรูปลูกศรชี้ขวา */
    clip-path: polygon(
        0% 0%, 
        85% 0%, 
        100% 50%, 
        85% 100%, 
        0% 100%, 
        0% 60%, 
        0% 40%
    );
}

/* ข้อความ "ชั้น 2" ใหม่ */
.floor2-sign-right-text {
    color: white;
    font-family: 'Kanit', sans-serif;
    font-size: clamp(12px, 2.5vw, 18px);
    font-weight: 700;
    text-shadow: 
        1px 1px 2px rgba(0, 0, 0, 0.8),
        0 0 4px rgba(0, 0, 0, 0.6);
    z-index: 1;
    position: relative;
    letter-spacing: 1px;
    margin-right: 8px;
}

/* เอฟเฟกต์เมื่อกำลังอยู่ชั้น 2 */
.floor2-sign-right.current-floor::after {
    background: linear-gradient(135deg, #228B22 0%, #32CD32 100%);
    animation: glow 2s ease-in-out infinite alternate;
}

.floor2-sign-right.current-floor .floor2-sign-right-text {
    color: #FFFFFF;
    text-shadow: 
        1px 1px 2px rgba(0, 0, 0, 0.8),
        0 0 8px rgba(50, 205, 50, 0.6);
}

/* Hover effect */
.floor2-sign-right:hover {
    transform: scale(1.05);
    transition: transform 0.2s ease;
}

.floor2-sign-right:active {
    transform: scale(0.95);
}

/* Responsive */
@media (max-width: 480px) {
    .floor2-sign-right {
        grid-column: 82 / 95;
        grid-row: 57 / 63;
    }
    
    .floor2-sign-right-text {
        font-size: 10px;
        letter-spacing: 0.5px;
        margin-right: 6px;
    }
}

@media (min-width: 481px) and (max-width: 768px) {
    .floor2-sign-right {
        grid-column: 82 / 95;
        grid-row: 57 / 63;
    }
    
    .floor2-sign-right-text {
        font-size: 14px;
        margin-right: 7px;
    }
}

@media (min-width: 1025px) {
    .floor2-sign-right {
        grid-column: 82 / 95;
        grid-row: 57 / 63;
    }
    
    .floor2-sign-right-text {
        font-size: 20px;
        letter-spacing: 1.5px;
        margin-right: 10px;
    }
}


